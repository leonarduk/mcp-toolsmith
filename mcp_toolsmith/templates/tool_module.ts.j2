import type { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
import { getApiBaseUrl, getApiToken } from "../config.js";

export function register{{ group.module_name|capitalize }}Tools(server: McpServer): void {
{% for op in group.operations %}  server.tool(
    "{{ op.operation_id }}",
    {{ op.summary | tojson }},
    {
{% for param in op.params %}      {{ param.name }}: {{ param.schema | tojson }},
{% endfor %}{% if op.has_request_body %}      body: {{ op.request_body_schema | tojson }},
{% endif %}    },
    async (args: Record<string, unknown>) => {
      const apiBaseUrl = getApiBaseUrl();
      const apiToken = getApiToken();
      const url = new URL(`${apiBaseUrl}{{ op.path_template }}`);
{% for param in op.params %}{% if param.location == 'query' %}      if (args.{{ param.name }} !== undefined) {
        url.searchParams.set("{{ param.name }}", String(args.{{ param.name }}));
      }
{% endif %}{% endfor %}      const response = await fetch(url, {
        method: "{{ op.http_method }}",
        headers: {
          "Accept": "application/json",
          ...(apiToken ? { Authorization: `Bearer ${apiToken}` } : {}),
{% if op.has_request_body %}          "Content-Type": "application/json",
{% endif %}        },
{% if op.has_request_body %}        body: JSON.stringify(args.body ?? {}),
{% endif %}      });
      const text = await response.text();
      return {
        content: [
          {
            type: "text" as const,
            text,
          },
        ],
      };
    },
  );
{% endfor %}}
